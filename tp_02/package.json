{
  "name": "demoserver",
  "version": "1.0.0",
  "description": "Simple application server",
  "main": "src/index.ts",
  "scripts": {
    "prod": "NODE_PATH=dist NODE_ENV=production node dist/src/index.js",
    "start": "ts-node src/index.ts",
    "watch": "nodemon",
    "inspect": "NODE_OPTIONS='--inspect' ts-node src/index.ts",
    "build": "tsc --project tsconfig.production.json",
    "clean": "tsc --build --clean",
    "tsc": "tsc",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch --detectOpenHandles src",
    "lint": "eslint ."
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.1.1",
    "@tsconfig/recommended": "^1.0.6",
    "@types/config": "^3.3.4",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.1",
    "@types/node": "^20.12.7",
    "@types/response-time": "^2.3.8",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^8.57.0",
    "globals": "^15.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "2.8.8",
    "ts-jest": "^29.0.5",
    "ts-node": "^10.9.1",
    "typescript": "^5.4.5",
    "typescript-eslint": "^7.8.0"
  },
  "dependencies": {
    "@types/morgan": "^1.9.10",
    "config": "^4.4.1",
    "express": "^4.19.2",
    "morgan": "^1.10.1",
    "prom-client": "^15.1.2",
    "response-time": "^2.3.2",
    "winston": "^3.13.0",
    "winston-loki": "^6.1.4"
  }
}
